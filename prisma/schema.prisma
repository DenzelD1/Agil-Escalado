// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ---------------------------------------------------------------------------
// Cliente
// ---------------------------------------------------------------------------
model Client {
  id        String   @id @default(uuid())
  nombre    String
  email     String   @unique
  telefono  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  addresses Address[]
}

// ---------------------------------------------------------------------------
// Dirección de envío
// ---------------------------------------------------------------------------
model Address {
  id               String  @id @default(uuid())
  calle            String
  numero           String
  ciudad           String
  region           String?
  codigoPostal     String?
  pais             String  @default("CHILE")
  notasAdicionales String?

  clienteId String?
  cliente   Client? @relation(fields: [clienteId], references: [id])

  orders Order[]
}

// ---------------------------------------------------------------------------
// Pedido
// ---------------------------------------------------------------------------
model Order {
  id         String   @id @default(uuid())
  idCanal    String
  tipoCanal  String
  estado     String   @default("creado")
  prioridad  String   @default("media")
  subtotal   Float
  impuestos  Float
  total      Float
  agenteId   String?
  recibidoEn DateTime @default(now())
  updatedAt  DateTime @updatedAt

  clienteId String
  cliente   Client @relation(fields: [clienteId], references: [id])

  direccionId String
  direccion   Address @relation(fields: [direccionId], references: [id])

  items             Item[]
  stockReservations StockReservation[]
}

// ---------------------------------------------------------------------------
// Ítem del pedido (SKU)
// ---------------------------------------------------------------------------
model Item {
  id             String @id @default(uuid())
  sku            String
  cantidad       Int
  precioUnitario Float
  descuento      Float  @default(0)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Reserva de stock (referencia al servicio de inventario externo)
// ---------------------------------------------------------------------------
model StockReservation {
  id        String   @id @default(uuid())
  sku       String
  cantidad  Int
  reservaId String
  createdAt DateTime @default(now())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
